# Orchestrator v3 — Environment Variables
# Copy to .env and customize for your setup.
# All variables are OPTIONAL — the system works with defaults.

# ── Auto-Orchestration (CEO Mode) ──

# Opt out of CEO mode (default: on for main sessions)
# export ORCHESTRATE_MODE=0

# Session type (set automatically by the orchestrator, don't set manually)
# CLAUDE_SESSION_TYPE=main|spinoff|cron|specialist

# Agent ID (set automatically for worker sessions)
# ORCHESTRATOR_AGENT_ID=<agent-name>

# ── Paths & Infrastructure ──

# Root directory for orchestrated workspaces (heads, grunts, done)
ORCHESTRATED_ROOT=~/projects/_orchestrated

# Path to the orchestrator.sh script (auto-detected if co-located)
# ORCHESTRATOR_SH=~/projects/orchestrator-v3/orchestrator.sh

# Vault directory for context files referenced in agent profiles ($VAULT)
VAULT_DIR=~/vault

# ── Multi-Machine (optional) ──

# Cross-machine relay command
# RELAY_CMD=~/projects/relay/relay.py

# Hub machine name (for multi-machine routing)
# HUB_MACHINE=hub

# Machine name override (defaults to hostname)
# MACHINE=hub

# Space-separated list of machine names (for orchestrator.sh machines command)
# MACHINES="hub worker-1 worker-2"

# External log command (called with: $ORCHESTRATOR_LOG_CMD <event> <job-id> <details>)
# ORCHESTRATOR_LOG_CMD="python3 ~/scripts/log-orchestration.py"
